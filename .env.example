# Copy this file to .env and fill in your values.
# All EXPO_PUBLIC_* variables are bundled into the client at build time — never put secrets here.

# Base URL of the VeeGo backend API (no trailing slash).
# Example: https://your-backend.replit.dev/api
EXPO_PUBLIC_API_URL=

# Set to 'true' to show the "Demo Trip" button on the login screen.
# Leave unset (or set to anything other than 'true') in production — the button is invisible.
EXPO_PUBLIC_DEMO_ENABLED=false

# Google Maps API keys — required for native map rendering on Android and iOS.
# Create separate keys in Google Cloud Console (Maps SDK for Android / Maps SDK for iOS).
# Restrict each key to the correct package name / bundle ID.
# Store production values as EAS secrets, never committed here.
GOOGLE_MAPS_API_KEY_ANDROID=
GOOGLE_MAPS_API_KEY_IOS=

# Certificate pinning (see docs/certificate-pinning.md) — comma-separated
# base64-encoded SHA-256 hashes of the VeeGo backend certificate's public key
# (Subject Public Key Info). Provide at least 2 (primary + backup pin).
# These are public-key hashes, not secrets — safe to bundle into the client.
# Required in production builds; pinning is skipped with a warning in dev
# if left unset.
EXPO_PUBLIC_CERT_PIN_SHA256=
